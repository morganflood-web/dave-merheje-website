generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Show {
  id              String   @id @default(cuid())
  date            DateTime
  venue           String
  city            String
  provinceState   String?
  ticketUrl       String
  createdAt       DateTime @default(now())
}

model Release {
  id         String   @id @default(cuid())
  title      String
  year       Int
  awardText  String?
  coverImage String
  platforms  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
